# ── Python ──
__pycache__/
.venv/
.pytest_cache/
MagicMock/
test_output*.txt

# ── Node / frontend ──
node_modules/
dist/

# ── Secrets & env ──
.env
*.enc
data/master.key

# ── Local editor / Claude Code config ──
.claude/

# ── Generated artifacts ──
*.pdf
*.log

# ── User data (sensitive — never commit) ──
