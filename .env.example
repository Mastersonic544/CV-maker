# ── CV Maker environment variables ──
# Copy this file to `.env` and fill in your values.
# Only OPENROUTER_API_KEY is required to get started; the rest are optional
# and can also be configured per-user from the in-app "Setup APIs" screen.

# Required: all LLM calls (role suggestions, persona, CV/cover letter, interview).
# Without it the app falls back to mock responses. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: LinkedIn Easy Apply automation + DMs (Playwright)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Optional: Gmail SMTP for email applications.
# SMTP_PASSWORD must be a Gmail App Password, NOT your account password.
# https://support.google.com/accounts/answer/185833
SMTP_USER=
SMTP_PASSWORD=
SENDER_NAME=

# Optional: alternative LinkedIn scraping path (falls back to Playwright/mock if unset)
APIFY_TOKEN=

# Optional: override the default ./data storage location
# DATA_DIR=

# Legacy / unused (kept for backward compatibility)
GROQ_API_KEY=
